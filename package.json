    "crosscheck:skip": "node tools/crosscheck-skip.mjs",
    "crosscheck:tiled": "node tools/crosscheck-tiled.mjs",
    "probe:rescaled": "node tools/probe-rescaled.mjs",
    "probe:deep218": "node tools/probe-deep218.mjs",
    "smoke:gpu": "node tools/smoke-viewer.mjs",
    "probe:gpu": "node tools/probe-gpu-real.mjs",
    "probe:df64": "GPU=1 node tools/probe-df64.mjs",
    "probe:ftz": "GPU=1 node tools/probe-ftz.mjs",
